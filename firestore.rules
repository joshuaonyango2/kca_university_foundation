// firestore.rules
// KCA University Foundation — Firestore Security Rules
// Updated: full rules for all collections including new features

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isAuth()       { return request.auth != null; }
    function uid()          { return request.auth.uid; }
    function isAdmin()      { return isAuth() && (
      request.auth.token.email == 'admin@kca.ac.ke' ||
      request.auth.token.email == 'foundation@kca.ac.ke'
    ); }
    function isStaff()      { return isAuth() &&
      exists(/databases/$(database)/documents/staff/$(uid())); }
    function isAdminOrStaff() { return isAdmin() || isStaff(); }
    function ownsDoc(id)    { return isAuth() && uid() == id; }

    // ── Campaign categories (public read) ─────────────────────────────────
    match /campaign_categories/{id} {
      allow read:   if true;
      allow write:  if isAdminOrStaff();
    }

    // ── Donor types (public read) ─────────────────────────────────────────
    match /donor_types/{id} {
      allow read:   if true;
      allow write:  if isAdminOrStaff();
    }

    // ── Payment methods (public read for active) ──────────────────────────
    match /payment_methods/{id} {
      allow read:   if true;
      allow write:  if isAdminOrStaff();
    }

    // ── Donation amounts (public read) ────────────────────────────────────
    match /donation_amounts/{id} {
      allow read:   if true;
      allow write:  if isAdminOrStaff();
    }

    // ── Campaigns (public read) ───────────────────────────────────────────
    match /campaigns/{id} {
      allow read:   if true;
      allow create: if isAdminOrStaff();
      allow update: if isAdminOrStaff()
                    || (isAuth()
                        && request.resource.data.keys().hasOnly(['raised']));
      allow delete: if isAdmin();
    }

    // ── Donors ────────────────────────────────────────────────────────────
    match /donors/{donorId} {
      allow read:   if ownsDoc(donorId) || isAdminOrStaff();
      allow create: if isAuth() && uid() == donorId;
      allow update: if ownsDoc(donorId) || isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // ── Donations ─────────────────────────────────────────────────────────
    match /donations/{id} {
      allow read:   if isAuth() &&
                       (resource.data.donor_id == uid()
                        || isAdminOrStaff());
      allow create: if isAuth();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // ── Receipts ──────────────────────────────────────────────────────────
    match /receipts/{id} {
      allow read:   if isAuth() &&
                       (resource.data.donor_email == request.auth.token.email
                        || isAdminOrStaff());
      allow create: if isAuth();
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{id} {
      // Donors: read/update their own + anything addressed to 'all'
      allow read:   if isAuth() &&
                       (resource.data.recipient_id == uid()
                        || resource.data.recipient_id == 'all'
                        || isAdminOrStaff());
      allow create: if isAuth();
      allow update: if isAuth() &&
                       (resource.data.recipient_id == uid()
                        || isAdminOrStaff());
      allow delete: if isAdmin();
    }

    // ── Staff ─────────────────────────────────────────────────────────────
    match /staff/{staffId} {
      allow read:   if ownsDoc(staffId) || isAdminOrStaff();
      allow create: if isAdmin();
      allow update: if ownsDoc(staffId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Roles ─────────────────────────────────────────────────────────────
    match /roles/{id} {
      allow read:   if isAdminOrStaff();
      allow write:  if isAdmin();
    }

    // ── Deposit slips (referenced via Storage URL) ────────────────────────
    match /deposit_slips/{id} {
      allow read:   if isAuth() &&
                       (resource.data.donor_id == uid()
                        || isAdminOrStaff());
      allow create: if isAuth();
      allow delete: if isAdmin();
    }
  }
}
